#!/bin/bash

# Define the weather codes
declare -A WEATHER_CODES=(
  ["113"]="вҳҖпёҸ "
  ["116"]="вӣ… "
  ["119"]="вҳҒпёҸ "
  ["122"]="вҳҒпёҸ "
  ["143"]="вҳҒпёҸ "
  ["176"]="рҹҢ§пёҸ"
  ["179"]="рҹҢ§пёҸ"
  ["182"]="рҹҢ§пёҸ"
  ["185"]="рҹҢ§пёҸ"
  ["200"]="вӣҲпёҸ "
  ["227"]="рҹҢЁпёҸ"
  ["230"]="рҹҢЁпёҸ"
  ["248"]="вҳҒпёҸ "
  ["260"]="вҳҒпёҸ "
  ["263"]="рҹҢ§пёҸ"
  ["266"]="рҹҢ§пёҸ"
  ["281"]="рҹҢ§пёҸ"
  ["284"]="рҹҢ§пёҸ"
  ["293"]="рҹҢ§пёҸ"
  ["296"]="рҹҢ§пёҸ"
  ["299"]="рҹҢ§пёҸ"
  ["302"]="рҹҢ§пёҸ"
  ["305"]="рҹҢ§пёҸ"
  ["308"]="рҹҢ§пёҸ"
  ["311"]="рҹҢ§пёҸ"
  ["314"]="рҹҢ§пёҸ"
  ["317"]="рҹҢ§пёҸ"
  ["320"]="рҹҢЁпёҸ"
  ["323"]="рҹҢЁпёҸ"
  ["326"]="рҹҢЁпёҸ"
  ["329"]="вқ„пёҸ "
  ["332"]="вқ„пёҸ "
  ["335"]="вқ„пёҸ "
  ["338"]="вқ„пёҸ "
  ["350"]="рҹҢ§пёҸ"
  ["353"]="рҹҢ§пёҸ"
  ["356"]="рҹҢ§пёҸ"
  ["359"]="рҹҢ§пёҸ"
  ["362"]="рҹҢ§пёҸ"
  ["365"]="рҹҢ§пёҸ"
  ["368"]="рҹҢ§пёҸ"
  ["371"]="вқ„пёҸ"
  ["374"]="рҹҢЁпёҸ"
  ["377"]="рҹҢЁпёҸ"
  ["386"]="рҹҢЁпёҸ"
  ["389"]="рҹҢЁпёҸ"
  ["392"]="рҹҢ§пёҸ"
  ["395"]="вқ„пёҸ "
)

# Make a request to wttr.in and store the response in a variable
weather=$(curl -s 'https://wttr.in/?format=j1')

# Parse the JSON response to get the current weather data
weather_code=$(echo $weather | jq -r '.current_condition[0].weatherCode')
feels_like=$(echo $weather | jq -r '.current_condition[0].FeelsLikeC')

# Format the weather data
tempint=$(echo $feels_like | cut -d. -f1)
extrachar=''
if [[ $tempint -gt 0 && $tempint -lt 10 ]]; then
  extrachar='+'
fi
text=$(printf "вҖү%s%sВ°" "${WEATHER_CODES[$weather_code]}" "$extrachar$feels_like")

# Print the formatted weather data as JSON
echo "{\"text\":\"$text\"}"
