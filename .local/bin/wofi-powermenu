#!/bin/env bash

OPTION_POWEROFF="箚맓 Power Off"
OPTION_REBOOT="箚쐣 Reboot"
OPTION_SUSPEND="箚쨪 Suspend"
OPTION_LOGOUT="箚늽 Logout"

OPTIONS="$OPTION_POWEROFF\n$OPTION_REBOOT\n$OPTION_SUSPEND\n$OPTION_LOGOUT"
CHOOSE=$(echo -e "$OPTIONS" | wofi -c ~/.config/wofi/powermenu.conf)

case "$CHOOSE" in
"$OPTION_POWEROFF")
	loginctl poweroff
	;;
"$OPTION_REBOOT")
	loginctl reboot
	;;
"$OPTION_SUSPEND")
	loginctl suspend
	;;
"$OPTION_LOGOUT")
	swaymsg exit
	;;
esac
