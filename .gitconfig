[user]
  name = "Max Miliano"
  email = "milianordelcanto@gmail.com"
[credential]
  helper = store
[pull]
  rebase = true
[init]
  defaultBranch = main
[diff]
  tool = nvimdiff
[merge]
  tool = nvimdiff
  conflictstyle = diff3
[merge]
  conflictstyle = zdiff3
[alias]
  dot = !git --git-dir=$HOME/.dot.git --work-tree=$HOME
  ai = add -i
  cm = !commit
  df = !git_diff
  dm = difftool --diff-filter=M
  ds = difftool --staged
  dd = difftool --diff-filter=D
  st = status
  graph = log --oneline --decorate --graph --all
  unstage = restore --staged --
  undo = restore
  submodule-update = !git submodule update --remote --merge
[fetch]
  prune = true
