vim9script
# :h option-list, to see all the options
set nu
set incsearch
set hlsearch
set bk
set mouse=a
set smartcase
set sms
set udf
set wrap
set ts=2
set sw=2
set siso=8
set rnu
set tgc
set fillchars+=eob:.
set bg=dark
set timeoutlen=300
set splitbelow
set ls=2
set scl=yes
set cole=3
set shell=zsh

&t_SI = "\e[6 q"
&t_EI = "\e[2 q"
